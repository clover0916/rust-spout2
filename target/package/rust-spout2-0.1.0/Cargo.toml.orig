[package]
name = "rust-spout2"
description = "Rust bindings for Spout2 on Windows."
version = "0.1.0"
edition = "2021"
authors = ["Timothy Yuen<timothy.yuen22@gmail.com"]
license = "MPL-2.0"
readme = "README.md"
repository = "https://github.com/youhu/rust-spout2"
homepage = "https://github.com/youhu/rust-spout2"
keywords = ["spout", "graphics", "windows", "interop"]
categories = ["api-bindings", "graphics"]

# See more keys and their definitions at https://doc.rust-lang.org/cargo/reference/manifest.html

[lib]
crate-type = ["cdylib", "lib"]

[features]
default = []
godot = ["dep:godot"]

[dependencies]
autocxx = "0.26"
# WHYYYYY https://github.com/google/autocxx/issues/739
cxx = "1.0"
godot = { version = "0.1", optional = true }
thiserror = "1.0"

[build-dependencies]
autocxx-build = "0.26"
cmake = "0.1"
